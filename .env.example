APP_NAME="The Grand Lion Hotel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
FORCE_HTTPS=false
TRUSTED_PROXIES=
APP_TIMEZONE=Asia/Manila

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=false
SESSION_PATH=/
SESSION_DOMAIN=null

SEED_DEFAULT_PASSWORD=password
SEED_ADMIN_EMAIL=admin@hotel.test
SEED_ADMIN_PASSWORD=password

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=file
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"
QR_MERCHANT_NAME="The Grand Lion Hotel"
INSTAPAY_HOLDER_NAME="The Grand Lion Hotel"
INSTAPAY_NUMBER="0917-123-4567"
INSTAPAY_QR_IMAGE_URL=
# Paste your official QRPh/EMV payload (single-line) to auto-fill amount in InstaPay.
INSTAPAY_QR_PAYLOAD=
INSTAPAY_APP_LINK="https://www.bsp.gov.ph/PaymentAndSettlement/Instapay"
CARD_HOLDER_NAME="The Grand Lion Hotel"
CARD_ACCEPTANCE_NOTE="Accepted at hotel front desk terminal."

VITE_APP_NAME="${APP_NAME}"
